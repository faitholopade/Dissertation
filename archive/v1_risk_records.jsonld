      "@id": "https://example.org/risk-record/USFED/ELIS_Evidence_Classifier_Machine_Learning_(ML)_Tagging_Solution",
      "@type": "vair:RiskRecord",
      "source": "USFED",
      "dct:identifier": "ELIS Evidence Classifier Machine Learning (ML) Tagging Solution",
      "title": "ELIS Evidence Classifier Machine Learning (ML) Tagging Solution",
      "description": "To enable end users to navigate directly to the page(s) containing evidence documents of interest instead of sifting through large PDF documents. Evidence tagging intends to accelerate case processing by identifying specific types of documents (e.g., I-589, passport photo spread, marriage certificate) and applying a metadata tag to that document object in ELIS. This way, when a user opens a case with potentially hundreds of pages of evidence documents, rather than scrolling through them one at a time to find a specific document of interest, they have clickable \"bookmarks\" in the UI generated from these tags that will jump directly to the corresponding page. Tagged evidence. The system inputs an image (scanned document from Lockbox) and outputs either a specific label, such as \"Border Crossing Card - Front,\" or no label if that document is not recognized as one of the classes.",
      "annexDomain": "https://w3id.org/vair#UnspecifiedDomain",
      "actorRole": "https://w3id.org/dpv#AIDeployer",
      "systemPattern": "https://w3id.org/vair#UnspecifiedPattern",
      "rights": [
        "https://w3id.org/dpv/legal/eu/rights#FundamentalRights"
      ],
      "harms": [
        "https://w3id.org/dpv/risk#Harm"
      ],
      "notes": "Auto annotation v0.4 rule-based"
    },
