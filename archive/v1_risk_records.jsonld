      "@id": "https://example.org/risk-record/USFED/Linkage_and_Matching_Program_(LaMP)",
      "@type": "vair:RiskRecord",
      "source": "USFED",
      "dct:identifier": "Linkage and Matching Program (LaMP)",
      "title": "Linkage and Matching Program (LaMP)",
      "description": "This use case involves probabilistic record linkage to link multiple person-level datasets. The predicted links are used for downstream processing to enable research regarding economic, demographic, and other topics and improve quality and efficiency of multiple Census operations. The AI produces a prediction regarding whether two records match. Output from the model is pairs of records above a minimum threshold indicating a match along with the score describing the similarity between the two records in the pair.",
      "annexDomain": "https://w3id.org/vair#UnspecifiedDomain",
      "actorRole": "https://w3id.org/dpv#AIDeployer",
      "systemPattern": "https://w3id.org/vair#UnspecifiedPattern",
      "rights": [
        "https://w3id.org/dpv/legal/eu/rights#FundamentalRights"
      ],
      "harms": [
