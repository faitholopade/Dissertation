      "@id": "https://example.org/risk-record/USFED/Automated_Change_Detection",
      "@type": "vair:RiskRecord",
      "source": "USFED",
      "dct:identifier": "Automated Change Detection",
      "title": "Automated Change Detection",
      "description": "As part of the Census Bureau's efforts to maintain and update the Geographic Frame ahead of the 2030 Decennial Census, the Geography Division is using AI to identify changes in the built environment throughout the nation twice a year. With the areas of change we are extracting our own geographic features (roads, building footprints) to support improving coverage across the nation. We use Google Earth Engine to analyze change in construction using Sentinel-2 imagery and recommend where to use high resolution imagery. The object detection provides roads and building footprints to improve our feature coverage.",
      "annexDomain": "https://w3id.org/vair#UnspecifiedDomain",
      "actorRole": "https://w3id.org/dpv#AIDeployer",
      "systemPattern": "https://w3id.org/vair#UnspecifiedPattern",
      "rights": [
        "https://w3id.org/dpv/legal/eu/rights#FundamentalRights"
      ],
      "harms": [
